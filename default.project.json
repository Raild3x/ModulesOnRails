{
    "name": "rail-modules",
    "emitLegacyScripts": false,
    "tree": {
        "$className": "DataModel",
        
        "ReplicatedStorage": {
            "$className": "ReplicatedStorage",
            "src": {
                "$path": "lib"
            },
            "test": {
                "$path": "test"
            }
        },

        "HttpService": {
            "$className": "HttpService",
            "$properties": {
                "HttpEnabled": true
            }
        }
    }
}